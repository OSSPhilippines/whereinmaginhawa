# Supabase Configuration
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# MagicUI API Key (optional)
NEXT_PUBLIC_MAGICUI_API_KEY=your_api_key_here

# Google Analytics Measurement ID
# Instructions to get ID:
# 1. Go to https://analytics.google.com/
# 2. Select your property or create a new one
# 3. Go to Admin → Data Streams → Web
# 4. Copy the "Measurement ID" (starts with G-)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense Publisher ID
# Instructions to get ID:
# 1. Go to https://www.google.com/adsense/
# 2. Sign in to your AdSense account
# 3. Go to Account → Account information
# 4. Copy your "Publisher ID" (starts with ca-pub-)
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

NEXT_PUBLIC_SITE_URL=http://localhost:3000
